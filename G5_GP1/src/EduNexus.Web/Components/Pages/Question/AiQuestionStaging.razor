@page "/ai-question-staging"
@inject IDbContextFactory<EduNexusDbContext> DbFactory
@inject EduNexus.Api.Question.Services.IQuestionService QuestionService

<PageTitle>AI Question Staging</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Trợ lý AI <span class="badge bg-info text-dark fs-6 rounded-pill align-text-top ms-2">BR-07</span></h2>
        <p class="text-muted mb-0">Tự động phân tích văn bản nguồn và gợi ý câu hỏi trắc nghiệm.</p>
    </div>
</div>

<div class="lms-card border-primary shadow-sm rounded-4 mb-5" style="border-width: 2px;">
    <div class="card-body p-4">
        <label class="form-label fw-bold text-primary mb-3">
            <i class="bi bi-magic me-2"></i>Cung cấp văn bản nguồn cho AI
        </label>
        <textarea class="form-control bg-light border-0 mb-3" rows="4" @bind="source" placeholder="Dán nội dung bài học, tài liệu hoặc đoạn văn vào đây..."></textarea>
        <select class="form-select mb-3" @bind="moduleId">
            <option value="">-- Chọn module nhận câu hỏi sau khi duyệt --</option>
            @if (modules is not null)
            {
                @foreach (var module in modules)
                {
                    <option value="@module.Id">@module.Title</option>
                }
            }
        </select>
        <div class="d-flex justify-content-end">
            <button class="btn btn-primary rounded-pill px-4 shadow-sm" @onclick="Generate" disabled="@(string.IsNullOrWhiteSpace(source) || isGenerating)">
                @if (isGenerating)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    <span>Đang sinh câu hỏi...</span>
                }
                else
                {
                    <i class="bi bi-robot me-2"></i>
                    <span>Sinh câu hỏi</span>
                }
            </button>
        </div>
    </div>
</div>

<h5 class="fw-bold mb-3"><i class="bi bi-inbox me-2"></i>Khu vực chờ duyệt (Staging)</h5>

<div class="lms-card border-0 shadow-sm rounded-4 overflow-hidden">
    @if (drafts is null)
    {
        <div class="p-4 text-center text-muted">Đang tải dữ liệu AI...</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 w-75 text-secondary">Nội dung sinh ra (JSON)</th>
                        <th class="text-secondary">Trạng thái</th>
                        <th class="text-end pe-4 text-secondary">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @foreach (var d in drafts)
                    {
                        <tr>
                            <td class="ps-4 py-3">
                                <div class="bg-dark text-light p-2 rounded-3" style="max-height: 100px; overflow-y: auto; font-family: monospace; font-size: 0.85rem;">
                                    @d.GeneratedJson
                                </div>
                            </td>
                            <td>
                                <span class="badge @(d.Status == "Approved" ? "bg-success bg-opacity-10 text-success" : "bg-warning bg-opacity-10 text-warning") rounded-pill px-3">
                                    @(d.Status == "Approved" ? "Đã duyệt" : "Chờ duyệt")
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                @if (d.Status == "Pending")
                                {
                                    <button class="btn btn-sm btn-outline-success rounded-pill px-3" @onclick="() => Approve(d.Id)">
                                        <i class="bi bi-check-circle me-1"></i> Duyệt
                                    </button>
                                }
                                else
                                {
                                    <span class="text-muted small"><i class="bi bi-check2-all me-1"></i>Hoàn tất</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (drafts.Count == 0)
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted p-4">Chưa có bản nháp nào được tạo.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>


@code {
    private string source = "";
    private string? moduleId;
    private List<Module>? modules;
    private List<EduNexus.Api.Question.Entities.AiQuestionDraft>? drafts;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        drafts = await db.AiQuestionDrafts.OrderByDescending(d => d.CreatedAt).ToListAsync();
        modules = await db.Modules.OrderBy(m => m.OrderIndex).ThenBy(m => m.Title).ToListAsync();
    }

    [Inject] private EduNexus.Api.Infrastructure.Ai.IAiContentService AiService { get; set; } = default!;
    private bool isGenerating = false;

    private async Task Generate()
    {
        if (string.IsNullOrWhiteSpace(source) || !Guid.TryParse(moduleId, out var targetModuleId)) return;
        isGenerating = true;
        StateHasChanged();

        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var anyUser = await db.Users.Select(u => (Guid?)u.Id).FirstOrDefaultAsync();
            await QuestionService.GenerateDraftAsync(
                new EduNexus.Api.Question.DTOs.GenerateQuestionRequest(targetModuleId, source, 5), anyUser ?? Guid.Empty);
            source = "";
        }
        finally
        {
            isGenerating = false;
            await Load();
        }
    }

    private async Task Approve(Guid id)
    {
        await QuestionService.ApproveDraftAsync(id);
        await Load();
    }
}
