@page "/login"
@layout EduNexus.Web.Components.Layout.EmptyLayout
@using EduNexus.Web.Services
@inject UserSession Session
@inject NavigationManager NavManager
@inject IConfiguration Configuration

<PageTitle>Đăng nhập | EduNexus</PageTitle>

<div class="row g-0 auth-page" style="min-height: 100vh;">
    <section class="col-md-6 d-none d-md-flex flex-column justify-content-center align-items-center text-white p-5" style="background: var(--lms-primary-gradient);">
        <div class="text-center" style="max-width: 32rem;">
            <div class="d-inline-flex align-items-center justify-content-center bg-white rounded-circle shadow mb-4" style="width: 5rem; height: 5rem; color: var(--lms-primary); font-size: 2.25rem;">
                <i class="bi bi-mortarboard-fill"></i>
            </div>
            <h1 class="display-5 fw-bold mb-3">EduNexus LMS</h1>
            <p class="lead mb-0">Nền tảng học tập và đào tạo tích hợp AI.</p>
        </div>
    </section>

    <main class="col-md-6 d-flex justify-content-center align-items-center bg-white p-4">
        <div class="w-100" style="max-width: 26.25rem;">
            <header class="mb-4 text-center">
                <h2 class="h3 fw-bold text-dark mb-2">Chào mừng trở lại</h2>
                <p class="text-muted mb-0">Đăng nhập để tiếp tục sử dụng EduNexus.</p>
            </header>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger small" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
                </div>
            }

            <form @onsubmit="HandleLogin">
                <div class="mb-3">
                    <label class="form-label fw-semibold" for="login-email">Email</label>
                    <input id="login-email" type="email" class="form-control" @bind="email" autocomplete="email" required placeholder="name@example.com" />
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <label class="form-label fw-semibold" for="login-password">Mật khẩu</label>
                        <a href="/forgot-password" class="small">Quên mật khẩu?</a>
                    </div>
                    <input id="login-password" type="password" class="form-control" @bind="password" autocomplete="current-password" required placeholder="Nhập mật khẩu" />
                </div>
                <button type="submit" class="btn lms-btn-primary w-100 py-2" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span><span>Đang đăng nhập…</span>
                    }
                    else
                    {
                        <span>Đăng nhập</span>
                    }
                </button>
            </form>

            <div class="d-flex align-items-center my-4" aria-hidden="true">
                <hr class="flex-grow-1" /><span class="px-3 text-muted small">HOẶC</span><hr class="flex-grow-1" />
            </div>

            @if (string.IsNullOrWhiteSpace(GoogleClientId))
            {
                <div class="alert alert-warning small mb-0">Google Client ID chưa được cấu hình trên máy này.</div>
            }
            else
            {
                <div data-google-signin data-client-id="@GoogleClientId" data-login-uri="@GoogleLoginUri">
                    <div data-google-fallback>
                        <button type="button" class="btn btn-outline-dark w-100 py-2 fw-semibold d-flex align-items-center justify-content-center gap-2"
                                onclick="window.eduNexusGoogleSignIn.start(this.closest('[data-google-signin]'))">
                            <i class="bi bi-google"></i><span>Tiếp tục với Google</span>
                        </button>
                        <p class="small text-muted text-center mt-2 mb-0" data-google-status>Đang tải Google Sign-In…</p>
                    </div>
                    <div data-google-official-button class="d-flex justify-content-center"></div>
                </div>
            }

            <p class="text-center small text-muted mt-4 mb-0">Chưa có tài khoản? <a href="/register" class="fw-semibold">Đăng ký ngay</a></p>

            <section class="mt-5 p-3 rounded-3" style="background: var(--lms-surface); border: 1px dashed var(--lms-border);">
                <p class="small text-muted mb-2 text-center fw-semibold">Tài khoản demo</p>
                <div class="d-flex justify-content-center gap-2 flex-wrap">
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick='@(() => FillForm("admin@edunexus.vn", "admin123"))'>Admin</button>
                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick='@(() => FillForm("sme.nguyen@edunexus.vn", "sme123"))'>SME</button>
                    <button type="button" class="btn btn-sm btn-outline-success" @onclick='@(() => FillForm("student.le@edunexus.vn", "student123"))'>Student</button>
                </div>
            </section>
        </div>
    </main>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    private string email = string.Empty;
    private string password = string.Empty;
    private string? errorMessage;
    private bool isLoading;
    private string GoogleClientId => Configuration["Authentication:Google:ClientId"] ?? string.Empty;
    private string GoogleLoginUri => $"{NavManager.BaseUri.TrimEnd('/')}/auth/google-token";

    protected override void OnParametersSet()
    {
        errorMessage = Error switch
        {
            "google_not_configured" => "Google Sign-In chưa có Client ID trên máy chủ. Vui lòng cấu hình Client ID rồi thử lại.",
            "google_auth_failed" => "Google không xác thực được tài khoản này. Vui lòng thử lại.",
            "no_email" => "Google không cung cấp email cho tài khoản này.",
            _ => null
        };
    }

    private void FillForm(string selectedEmail, string selectedPassword)
    {
        email = selectedEmail;
        password = selectedPassword;
        errorMessage = null;
    }

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;
        if (!await Session.LoginWithEmailAsync(email, password))
        {
            errorMessage = "Email hoặc mật khẩu không chính xác.";
            isLoading = false;
            return;
        }

        var destination = Session.IsInRole("SME", "Teacher", "CourseManager") ? "/courses" : "/dashboard";
        NavManager.NavigateTo(destination, forceLoad: true);
    }
}
