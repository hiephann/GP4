@page "/"
@using EduNexus.Web.Services
@inject UserSession Session
@inject NavigationManager NavManager

<PageTitle>EduNexus — Đang tải...</PageTitle>

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="text-center">
        <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <h4 class="text-muted">Đang tải không gian làm việc...</h4>
    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Đợi Session init xong (MainLayout đã gọi InitializeAsync)
                int attempts = 0;
                while (!Session.IsInitialized && attempts < 20)
                {
                    await Task.Delay(100);
                    attempts++;
                }

                if (!Session.IsLoggedIn)
                {
                    NavManager.NavigateTo("/login", forceLoad: false);
                    return;
                }

                var role = Session.CurrentRole?.Name;
                
                var target = role switch
                {
                    "Student" => "/dashboard",
                    "Admin" => "/dashboard",
                    "SME" or "Teacher" => "/courses",
                    _ => "/login"
                };
                
                NavManager.NavigateTo(target, forceLoad: false);
            }
            catch
            {
                NavManager.NavigateTo("/login", forceLoad: false);
            }
        }
    }
}
