@page "/assignment-detail"
@inject IDbContextFactory<EduNexusDbContext> DbFactory

<PageTitle>Assignment Detail - Cấu Hình</PageTitle>

<div class="page-header d-flex justify-content-between align-items-end mb-4">
    <div>
        <h2>Cấu Hình Bài Tập <span class="screen-tag">Assignment · FT-05</span></h2>
        <p class="text-muted mb-0">Biên soạn nội dung (Markdown) và thiết lập Rubric đánh giá.</p>
    </div>
    <div style="min-width: 300px;">
        <select class="form-select lms-input" value="@selectedId" @onchange="OnChanged">
            <option value="">-- Chuyển bài tập khác --</option>
            @if (items is not null)
            {
                @foreach (var a in items) { <option value="@a.Id">@a.Title</option> }
            }
        </select>
    </div>
</div>

@if (current is not null)
{
    <div class="row g-4">
        <!-- Cột Trái: Thông tin đề bài & Hạn nộp -->
        <div class="col-lg-6">
            <div class="lms-card p-4 h-100">
                <h5 class="fw-bold mb-3"><i class="bi bi-file-earmark-text text-primary me-2"></i>Nội dung Đề Bài</h5>
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small text-uppercase">Hạn Nộp</label>
                    <input type="date" class="form-control lms-input" @bind="dueDate" style="max-width:250px" />
                </div>
                <div class="mb-3 flex-grow-1 d-flex flex-column">
                    <label class="form-label fw-bold text-muted small text-uppercase">Đề bài (Hỗ trợ Markdown)</label>
                    <textarea class="form-control lms-focus-textarea flex-grow-1" rows="12" placeholder="Nhập đề bài chi tiết..." @bind="current.PromptMarkdown"></textarea>
                </div>
                <div class="text-end mt-auto">
                    <button class="btn lms-btn-primary" @onclick="SavePrompt">
                        <i class="bi bi-save me-1"></i> Lưu Thông Tin
                    </button>
                    @if (showSaveSuccess)
                    {
                        <span class="text-success ms-2 fw-bold animate__animated animate__fadeIn"><i class="bi bi-check-circle"></i> Đã lưu</span>
                    }
                </div>
            </div>
        </div>

        <!-- Cột Phải: Rubric -->
        <div class="col-lg-6">
            <div class="lms-card p-4 h-100 d-flex flex-column">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="fw-bold mb-0"><i class="bi bi-list-check text-primary me-2"></i>Tiêu Chí Chấm Điểm (Rubric)</h5>
                </div>
                
                <div class="mb-4">
                    <div class="d-flex justify-content-between small fw-bold mb-1">
                        <span class="text-muted">Tổng tỷ trọng</span>
                        <span class="@(TotalWeight == 100 ? "text-success" : "text-danger")">@TotalWeight% / 100%</span>
                    </div>
                    <div class="progress" style="height: 10px;">
                        <div class="progress-bar @(TotalWeight == 100 ? "bg-success" : (TotalWeight > 100 ? "bg-danger" : "bg-warning"))" 
                             role="progressbar" 
                             style="width: @(TotalWeight > 100 ? 100 : TotalWeight)%" 
                             aria-valuenow="@TotalWeight" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    @if(TotalWeight != 100)
                    {
                        <div class="small text-danger mt-1"><i class="bi bi-exclamation-triangle"></i> Tổng tỷ trọng phải đúng bằng 100%.</div>
                    }
                </div>

                <div class="table-responsive flex-grow-1 mb-3">
                    <table class="table lms-table">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-3">Tiêu chí</th>
                                <th>Tỷ trọng %</th>
                                <th>Điểm tối đa</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (criteria != null && criteria.Any())
                            {
                                @foreach (var c in criteria)
                                {
                                    <tr>
                                        <td class="ps-3 fw-bold">@c.Name</td>
                                        <td><span class="badge bg-secondary">@c.Weight%</span></td>
                                        <td>@c.MaxScore đ</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center py-4 text-muted fst-italic">Chưa có tiêu chí nào.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Thêm tiêu chí form -->
                <div class="p-3 bg-light rounded-3 border">
                    <h6 class="fw-bold mb-3 small text-uppercase text-muted">Thêm Tiêu Chí Mới</h6>
                    <div class="row g-2 align-items-end">
                        <div class="col-md-5">
                            <label class="form-label small mb-1">Tên tiêu chí</label>
                            <input class="form-control form-control-sm" placeholder="VD: Sáng tạo" @bind="cName" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small mb-1">Tỷ trọng (%)</label>
                            <input type="number" class="form-control form-control-sm" placeholder="20" @bind="cWeight" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small mb-1">Điểm tối đa</label>
                            <input type="number" class="form-control form-control-sm" placeholder="10" @bind="cMax" />
                        </div>
                        <div class="col-md-1 text-end">
                            <button class="btn btn-sm btn-primary w-100 h-100" @onclick="AddCriterion">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else if(Id is not null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Đang tải...</span>
        </div>
    </div>
}
else
{
    <div class="lms-card p-5 text-center text-muted">
        <i class="bi bi-hand-index-thumb fs-1 d-block mb-3"></i>
        <h4>Hãy chọn một bài tập từ menu bên trên để bắt đầu cấu hình.</h4>
    </div>
}

@code {
    private List<AssignmentItem>? items;
    private Guid? selectedId;
    private AssignmentItem? current;
    private List<RubricCriterion>? criteria;
    private DateTime? dueDate;
    private string cName = "";
    private decimal cWeight, cMax;
    private decimal TotalWeight => criteria?.Sum(x => x.Weight) ?? 0;
    private bool showSaveSuccess = false;

    [Microsoft.AspNetCore.Components.SupplyParameterFromQuery]
    [Microsoft.AspNetCore.Components.Parameter] public Guid? Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        items = await db.Assignments.OrderBy(a => a.Title).ToListAsync();
        if (Id is not null) { selectedId = Id; await LoadCurrent(); }
    }

    private async Task OnChanged(ChangeEventArgs e)
    {
        selectedId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null;
        showSaveSuccess = false;
        await LoadCurrent();
    }

    private async Task LoadCurrent()
    {
        if (selectedId is null) { current = null; return; }
        using var db = await DbFactory.CreateDbContextAsync();
        current = await db.Assignments.FindAsync(selectedId);
        dueDate = current?.DueDate;
        criteria = await db.RubricCriteria.Where(c => c.AssignmentId == selectedId).OrderBy(c => c.OrderIndex).ToListAsync();
    }

    private async Task SavePrompt()
    {
        if (current is null) return;
        using var db = await DbFactory.CreateDbContextAsync();
        var a = await db.Assignments.FindAsync(current.Id);
        if (a is not null) { 
            a.PromptMarkdown = current.PromptMarkdown; 
            a.DueDate = dueDate; 
            await db.SaveChangesAsync(); 
            
            showSaveSuccess = true;
            StateHasChanged();
            await Task.Delay(3000);
            showSaveSuccess = false;
            StateHasChanged();
        }
    }

    private async Task AddCriterion()
    {
        if (selectedId is null || string.IsNullOrWhiteSpace(cName) || cWeight <= 0) return;
        using var db = await DbFactory.CreateDbContextAsync();
        var order = await db.RubricCriteria.CountAsync(c => c.AssignmentId == selectedId) + 1;
        db.RubricCriteria.Add(new RubricCriterion { Id = Guid.NewGuid(), AssignmentId = selectedId.Value, Name = cName.Trim(), Weight = cWeight, MaxScore = cMax, OrderIndex = order });
        await db.SaveChangesAsync();
        cName = ""; cWeight = 0; cMax = 0;
        await LoadCurrent();
    }
}
