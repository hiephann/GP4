@page "/assignments"
@inject IDbContextFactory<EduNexusDbContext> DbFactory

<PageTitle>Assignment List</PageTitle>

<div class="page-header d-flex justify-content-between align-items-end">
    <div>
        <h2>Assignment List <span class="screen-tag">Assignment · FT-05</span></h2>
        <p class="text-muted mb-0">Quản lý bài tập tự luận và cấu hình rubric đánh giá.</p>
    </div>
</div>

<div class="lms-card p-4 mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label fw-bold text-muted small text-uppercase">Module</label>
            <select class="form-select lms-input" @bind="newModuleId">
                <option value="">-- Chọn module --</option>
                @if (modules is not null)
                {
                    @foreach (var m in modules) { <option value="@m.Id">@m.Title</option> }
                }
            </select>
        </div>
        <div class="col-md-5">
            <label class="form-label fw-bold text-muted small text-uppercase">Tiêu đề bài tập</label>
            <input class="form-control lms-input" placeholder="Nhập tiêu đề mới..." @bind="newTitle" />
        </div>
        <div class="col-md-3">
            <button class="btn lms-btn-primary w-100" @onclick="Add">
                <i class="bi bi-plus-circle me-1"></i> Tạo Bài Tập Mới
            </button>
        </div>
    </div>
</div>

@if (items is null) 
{ 
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Đang tải...</span>
        </div>
    </div>
}
else
{
    <div class="lms-card overflow-hidden">
        <table class="table lms-table mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4">Tiêu đề Bài Tập</th>
                    <th>Hạn Nộp</th>
                    <th>Trạng Thái</th>
                    <th class="text-end pe-4">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in items)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@a.Title</td>
                        <td>
                            @if(a.DueDate.HasValue)
                            {
                                <span class="text-muted"><i class="bi bi-calendar-event me-1"></i> @a.DueDate.Value.ToString("dd/MM/yyyy")</span>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Chưa đặt hạn</span>
                            }
                        </td>
                        <td>
                            @if(a.Status == "Published")
                            {
                                <span class="lms-badge lms-badge-published">Published</span>
                            }
                            else
                            {
                                <span class="lms-badge lms-badge-draft">Draft</span>
                            }
                        </td>
                        <td class="text-end pe-4">
                            <a class="btn btn-sm btn-outline-primary rounded-pill px-3" href="@($"assignment-detail?id={a.Id}")">
                                Cấu hình Rubric
                            </a>
                        </td>
                    </tr>
                }
                @if (items.Count == 0) 
                { 
                    <tr>
                        <td colspan="4" class="text-center py-4 text-muted">
                            <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                            Chưa có bài tập nào. Hãy tạo bài tập đầu tiên.
                        </td>
                    </tr> 
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<AssignmentItem>? items;
    private List<Module>? modules;
    private string newTitle = "";
    private string? newModuleId;

    protected override async Task OnInitializedAsync()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        modules = await db.Modules.OrderBy(m => m.Title).ToListAsync();
        await Load();
    }

    private async Task Load()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        items = await db.Assignments.OrderByDescending(a => a.CreatedAt).ToListAsync();
    }

    private async Task Add()
    {
        if (string.IsNullOrWhiteSpace(newTitle) || !Guid.TryParse(newModuleId, out var mid)) return;
        using var db = await DbFactory.CreateDbContextAsync();
        db.Assignments.Add(new AssignmentItem { Id = Guid.NewGuid(), ModuleId = mid, Title = newTitle.Trim(), Status = "Draft", CreatedAt = DateTime.UtcNow });
        await db.SaveChangesAsync();
        newTitle = "";
        await Load();
    }
}
