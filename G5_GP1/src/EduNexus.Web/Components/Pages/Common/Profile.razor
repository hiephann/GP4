@page "/profile"
@using EduNexus.Api.Common.Entities
@inject IDbContextFactory<EduNexusDbContext> DbFactory
@inject EduNexus.Web.Services.UserSession Session

<PageTitle>Hồ sơ cá nhân</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Hồ sơ cá nhân</h2>
        <p class="text-muted mb-0">Quản lý thông tin và bảo mật tài khoản.</p>
    </div>
</div>

@if (Session.CurrentUser is null)
{
    <p>Vui lòng đăng nhập.</p>
}
else
{
    <div class="row g-4">
        <div class="col-md-4">
            <div class="lms-card p-4 text-center">
                <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center mx-auto mb-3" style="width: 120px; height: 120px; font-size: 3rem;">
                    @Session.CurrentUser.DisplayName?.FirstOrDefault()
                </div>
                <h4 class="fw-bold mb-1">@Session.CurrentUser.DisplayName</h4>
                <p class="text-muted mb-2">@Session.CurrentUser.Email</p>
                <span class="badge bg-info text-dark rounded-pill px-3 py-2">
                    Vai trò: @Session.CurrentRole?.Name
                </span>
                
                <hr class="my-4" />
                
                <div class="text-start">
                    <p class="small text-muted text-uppercase fw-bold mb-2">Thông tin tài khoản</p>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Ngày tham gia:</span>
                        <span class="fw-medium">@Session.CurrentUser.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Đăng nhập qua:</span>
                        <span class="fw-medium">@Session.CurrentUser.AuthProvider</span>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-8">
            <div class="lms-card p-4 mb-4">
                <h5 class="fw-bold mb-4">Chỉnh sửa thông tin</h5>
                
                @if (isSuccess)
                {
                    <div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>Cập nhật thành công!</div>
                }
                
                <div class="mb-3">
                    <label class="form-label fw-semibold">Họ và tên</label>
                    <input type="text" class="form-control lms-input" @bind="editName" />
                </div>
                
                <div class="mb-3">
                    <label class="form-label fw-semibold">Email</label>
                    <input type="email" class="form-control lms-input" value="@Session.CurrentUser.Email" disabled />
                    <div class="form-text">Không thể thay đổi email sau khi đăng ký.</div>
                </div>
                
                <button class="btn lms-btn-primary mt-2" @onclick="UpdateProfile" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    <i class="bi bi-save me-1"></i> Lưu thay đổi
                </button>
            </div>
            
            <div class="lms-card p-4">
                <h5 class="fw-bold mb-4">Hạn mức AI (AI Quota)</h5>
                <p class="text-muted">Giới hạn số lần sử dụng AI trong tháng của bạn.</p>
                
                <div class="progress mb-2" style="height: 20px;">
                    <div class="progress-bar bg-primary" role="progressbar" style="width: 25%" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100">25 / 100</div>
                </div>
                <small class="text-muted">Đã dùng 25 lượt. Còn lại 75 lượt.</small>
            </div>
        </div>
    </div>
}

@code {
    private string editName = "";
    private bool isSuccess;
    private bool isLoading;

    protected override void OnInitialized()
    {
        if (Session.CurrentUser != null)
        {
            editName = Session.CurrentUser.DisplayName ?? "";
        }
    }

    private async Task UpdateProfile()
    {
        if (Session.CurrentUser == null || string.IsNullOrWhiteSpace(editName)) return;
        
        isLoading = true;
        isSuccess = false;
        
        using var db = await DbFactory.CreateDbContextAsync();
        var user = await db.Users.FindAsync(Session.CurrentUser.Id);
        if (user != null)
        {
            user.DisplayName = editName;
            await db.SaveChangesAsync();
            
            // Update session cache
            await Session.LoginAsync(user.Id);
            isSuccess = true;
        }
        
        isLoading = false;
    }
}
