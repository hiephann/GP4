@page "/assignments"
@inject IDbContextFactory<EduNexusDbContext> DbFactory

<PageTitle>Assignment List</PageTitle>

<div class="page-header">
    <h2>Assignment List <span class="screen-tag">Assignment · FT-05</span></h2>
    <p class="text-muted">Danh sách bài tập tự luận.</p>
</div>

<div class="card mb-3">
    <div class="card-body d-flex gap-2 align-items-end flex-wrap">
        <div style="min-width:240px">
            <label class="form-label">Module</label>
            <select class="form-select" @bind="newModuleId">
                <option value="">-- chọn module --</option>
                @if (modules is not null)
                {
                    @foreach (var m in modules) { <option value="@m.Id">@m.Title</option> }
                }
            </select>
        </div>
        <div style="min-width:240px">
            <label class="form-label">Tiêu đề bài tập</label>
            <input class="form-control" @bind="newTitle" />
        </div>
        <button class="btn btn-primary" @onclick="Add">+ Thêm</button>
    </div>
</div>

@if (items is null) { <p>Đang tải...</p> }
else
{
    <table class="table table-striped">
        <thead><tr><th>Tiêu đề</th><th>Hạn nộp</th><th>Trạng thái</th><th></th></tr></thead>
        <tbody>
            @foreach (var a in items)
            {
                <tr>
                    <td>@a.Title</td>
                    <td>@(a.DueDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                    <td><span class="badge bg-secondary">@a.Status</span></td>
                    <td><a class="btn btn-sm btn-outline-primary" href="@($"assignment-detail?id={a.Id}")">Chi tiết</a></td>
                </tr>
            }
            @if (items.Count == 0) { <tr><td colspan="4" class="text-muted">Chưa có bài tập.</td></tr> }
        </tbody>
    </table>
}

@code {
    private List<AssignmentItem>? items;
    private List<Module>? modules;
    private string newTitle = "";
    private string? newModuleId;

    protected override async Task OnInitializedAsync()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        modules = await db.Modules.OrderBy(m => m.Title).ToListAsync();
        await Load();
    }

    private async Task Load()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        items = await db.Assignments.OrderByDescending(a => a.CreatedAt).ToListAsync();
    }

    private async Task Add()
    {
        if (string.IsNullOrWhiteSpace(newTitle) || !Guid.TryParse(newModuleId, out var mid)) return;
        using var db = await DbFactory.CreateDbContextAsync();
        db.Assignments.Add(new AssignmentItem { Id = Guid.NewGuid(), ModuleId = mid, Title = newTitle.Trim(), Status = "Draft", CreatedAt = DateTime.UtcNow });
        await db.SaveChangesAsync();
        newTitle = "";
        await Load();
    }
}
