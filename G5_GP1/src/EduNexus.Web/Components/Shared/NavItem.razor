@inherits ComponentBase

<div class="nav-item px-3 mb-1">
    <NavLink class="nav-link d-flex align-items-center gap-2 py-2 px-3 rounded-2 text-muted" 
             href="@Href" style="transition: all 0.2s; font-size: 0.9rem; font-weight: 500;">
        <i class="bi @Icon fs-6" style="width: 24px;"></i> 
        <span>@Text</span>
    </NavLink>
</div>

@code {
    [Parameter]
    public string Href { get; set; } = "";

    [Parameter]
    public string Icon { get; set; } = "bi-circle";

    [Parameter]
    public string Text { get; set; } = "";
}
