@page "/assignment-submit"
@inject IDbContextFactory<EduNexusDbContext> DbFactory
@inject EduNexus.Api.Assignment.Services.IAssignmentService AssignmentService
@inject EduNexus.Web.Services.UserSession Session

<PageTitle>Nộp Bài Tập — EduNexus</PageTitle>

<!-- Page Header -->
<div class="page-header text-center mb-3">
    <h2>Nộp Bài Tập <span class="screen-tag">Assignment · FT-08</span></h2>
    <p class="text-muted mb-0">Viết và nộp bài làm của bạn. Hệ thống sẽ tự động chấm điểm sơ bộ bằng AI.</p>
</div>

<!-- Step Flow Navigator -->
@if (Session.IsInRole("Student"))
{
    <div class="lms-step-flow">
        <a class="step active" href="assignment-submit"><i class="bi bi-upload"></i> 1. Nộp bài</a>
        <div class="step-divider"></div>
        <a class="step" href="assignment-result"><i class="bi bi-clipboard-check"></i> 2. Kết quả</a>
    </div>
}
<div class="lms-step-flow d-none">
    <a class="step completed" href="assignments">
        <i class="bi bi-check-circle-fill"></i> 1. Tạo Bài Tập
    </a>
    <div class="step-divider"></div>
    <a class="step completed" href="assignment-detail">
        <i class="bi bi-check-circle-fill"></i> 2. Cấu Hình Rubric
    </a>
    <div class="step-divider"></div>
    <a class="step active" href="assignment-submit">
        <i class="bi bi-upload"></i> 3. Nộp Bài
    </a>
    <div class="step-divider"></div>
    <a class="step" href="assignment-result">
        <i class="bi bi-clipboard-check"></i> 4. Kết Quả
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-10">
        <!-- Selection Panel -->
        <div class="lms-card p-4 mb-4 fade-in">
            <div class="lms-section-header">
                <i class="bi bi-sliders"></i>
                <div>
                    <h5>Chọn Bài Tập & Học Viên</h5>
                    <div class="section-subtitle">Chọn bài tập đã xuất bản và tài khoản học viên.</div>
                </div>
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="lms-label"><i class="bi bi-file-earmark-text"></i> Bài tập</label>
                    <select class="form-select lms-input" @bind="assignmentId" @bind:after="OnAssignmentChanged" id="select-assignment">
                        <option value="">— Chọn bài tập (Published) —</option>
                        @if (items is not null)
                        {
                            @foreach (var a in items)
                            {
                                <option value="@a.Id">@a.Title</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="lms-label"><i class="bi bi-person"></i> Học viên (mô phỏng đăng nhập)</label>
                    <div class="form-control lms-input bg-light">@Session.CurrentUser?.DisplayName (@Session.CurrentUser?.Email)</div>
                    <select class="form-select lms-input" @bind="studentId" id="select-student" hidden aria-hidden="true">
                        <option value="">— Chọn học viên —</option>
                        @if (students is not null)
                        {
                            @foreach (var s in students)
                            {
                                <option value="@s.Id">@s.DisplayName (@s.Email)</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>

        <!-- Assignment Info Card -->
        @if (selectedAssignment is not null)
        {
            <div class="lms-card p-4 mb-4 fade-in border-left-primary">
                <div class="lms-section-header">
                    <i class="bi bi-info-circle"></i>
                    <div>
                        <h5>Thông Tin Bài Tập</h5>
                        <div class="section-subtitle">Đọc kỹ yêu cầu trước khi nộp bài.</div>
                    </div>
                </div>
                
                <div class="submission-info-strip">
                    <div class="info-item">
                        <i class="bi bi-bookmark-fill" style="color: var(--lms-primary);"></i>
                        <span class="info-label">Tên:</span>
                        <span class="info-value">@selectedAssignment.Title</span>
                    </div>
                    @if (selectedAssignment.DueDate.HasValue)
                    {
                        var isOverdue = selectedAssignment.DueDate.Value < DateTime.UtcNow;
                        <div class="info-item">
                            <i class="bi bi-calendar-event @(isOverdue ? "text-danger" : "")" style="@(!isOverdue ? "color: var(--lms-success);" : "")"></i>
                            <span class="info-label">Hạn nộp:</span>
                            <span class="info-value @(isOverdue ? "text-danger" : "")">
                                @selectedAssignment.DueDate.Value.ToString("dd/MM/yyyy")
                                @if (isOverdue) { <span class="ms-1 lms-badge lms-badge-danger">Quá hạn</span> }
                            </span>
                        </div>
                    }
                    <div class="info-item">
                        <i class="bi bi-text-paragraph" style="color: var(--lms-info);"></i>
                        <span class="info-label">Giới hạn:</span>
                        <span class="info-value">@selectedAssignment.MaxChars.ToString("N0") ký tự</span>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(selectedAssignment.PromptMarkdown))
                {
                    <div class="mt-3 p-3 rounded-3" style="background: var(--lms-background); border: 1px solid var(--lms-border-light);">
                        <div class="small fw-bold text-muted text-uppercase mb-2">
                            <i class="bi bi-markdown me-1"></i> Đề bài
                        </div>
                        <pre style="white-space: pre-wrap; font-family: inherit; margin: 0; font-size: 0.9rem; line-height: 1.7; color: var(--lms-text-main);">@selectedAssignment.PromptMarkdown</pre>
                    </div>
                }
            </div>
        }

        <!-- Writing Area -->
        <div class="lms-card p-4 fade-in">
            <div class="d-flex justify-content-between align-items-end mb-3">
                <div class="lms-section-header mb-0 pb-0" style="border: none;">
                    <i class="bi bi-journal-text"></i>
                    <div>
                        <h5>Bài Làm Của Bạn</h5>
                        <div class="section-subtitle">Trình bày bài làm rõ ràng, logic và đầy đủ.</div>
                    </div>
                </div>
                <span class="char-counter @CharCounterClass">
                    <i class="bi bi-body-text me-1"></i>
                    @content.Length / @maxChars.ToString("N0") ký tự
                </span>
            </div>

            <textarea class="form-control lms-focus-textarea mb-4" rows="16"
                      maxlength="@maxChars"
                      placeholder="Nhập nội dung bài làm của bạn tại đây...&#10;&#10;Hãy trình bày rõ ràng, có dẫn chứng và phân tích logic."
                      @bind="content" @bind:event="oninput" id="textarea-content"></textarea>

            <!-- Character usage bar -->
            <div class="lms-progress-bar mb-4">
                <div class="bar @CharBarClass" style="width: @CharPercent%"></div>
            </div>

            <!-- Action Footer -->
            <div class="d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-3">
                    <div class="text-muted small">
                        <i class="bi bi-info-circle me-1"></i> Mỗi học viên chỉ được nộp <strong>1 lần</strong> (NAC-08-b).
                    </div>
                </div>
                <button class="btn lms-btn-primary btn-lg px-5" @onclick="Submit"
                        disabled="@(isSubmitting || string.IsNullOrWhiteSpace(content))"
                        id="btn-submit">
                    @if (isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        <span>Đang xử lý AI...</span>
                    }
                    else
                    {
                        <i class="bi bi-send-check me-2"></i><span>Nộp Bài</span>
                    }
                </button>
            </div>

            @if (message is not null)
            {
                <div class="alert @(ok ? "alert-success" : "alert-danger") mt-4 d-flex align-items-start gap-3 slide-up" role="alert">
                    <i class="bi @(ok ? "bi-check-circle-fill text-success" : "bi-exclamation-triangle-fill text-danger") fs-4"></i>
                    <div>
                        <div class="fw-bold mb-1">@(ok ? "Nộp bài thành công!" : "Không thể nộp bài")</div>
                        <div class="small">@message</div>
                        @if (ok)
                        {
                            <a href="assignment-result" class="btn btn-sm lms-btn-success mt-2">
                                <i class="bi bi-bar-chart me-1"></i> Xem Kết Quả
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<AssignmentItem>? items;
    private List<User>? students;
    private AssignmentItem? selectedAssignment;
    private string? assignmentId, studentId;
    private string content = "";
    private string? message;
    private bool ok;
    private bool isSubmitting = false;
    private int maxChars = 20000;

    private double CharPercent => maxChars > 0 ? Math.Min((double)content.Length / maxChars * 100, 100) : 0;
    private string CharCounterClass => content.Length > maxChars * 0.9 ? "danger" 
                                     : content.Length > maxChars * 0.7 ? "warning" 
                                     : "normal";
    private string CharBarClass => content.Length > maxChars * 0.9 ? "bar-danger" 
                                 : content.Length > maxChars * 0.7 ? "bar-warning" 
                                 : "bar-primary";

    protected override async Task OnInitializedAsync()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        // Only show Published assignments
        items = await db.Assignments
            .Where(a => a.Status == "Published")
            .OrderBy(a => a.Title)
            .ToListAsync();
        students = await db.Users.OrderBy(u => u.DisplayName).ToListAsync();
    }

    private void OnAssignmentChanged()
    {
        if (Guid.TryParse(assignmentId, out var aid))
        {
            selectedAssignment = items?.FirstOrDefault(a => a.Id == aid);
            maxChars = selectedAssignment?.MaxChars ?? 20000;
        }
        else
        {
            selectedAssignment = null;
            maxChars = 20000;
        }
        message = null;
    }

    private async Task Submit()
    {
        if (!Guid.TryParse(assignmentId, out var aid) || Session.CurrentUser is null)
        {
            ok = false;
            message = "Vui lòng chọn bài tập và học viên trước khi nộp.";
            return;
        }
        if (string.IsNullOrWhiteSpace(content))
        {
            ok = false;
            message = "Bài nộp không được để trống (NAC-08-d).";
            return;
        }

        isSubmitting = true;
        StateHasChanged();

        try
        {
            var submissionId = await AssignmentService.SubmitAsync(aid,
                new EduNexus.Api.Assignment.DTOs.SubmitAssignmentRequest(Session.CurrentUser.Id, content));
            using var db = await DbFactory.CreateDbContextAsync();
            var submission = await db.Submissions.FindAsync(submissionId);
            content = "";
            ok = true;
            message = submission?.Status == "AiGraded"
                ? $"Gemini đã chấm sơ bộ: {submission.AiTotalScore:0.#} điểm. Giáo viên sẽ xác nhận điểm cuối."
                : "Bài đã được nộp. AI chưa trả kết quả, giáo viên sẽ chấm và xác nhận.";
        }
        catch (InvalidOperationException ex)
        {
            ok = false;
            message = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
