@page "/courses"
@using EduNexus.Api.Common.Entities
@using EduNexus.Web.Services
@inject UserSession Session
@inject IDbContextFactory<EduNexusDbContext> DbFactory

<PageTitle>Course List — SME</PageTitle>

<div class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2>Quản lý Khóa học <span class="screen-tag">Common · SME</span></h2>
            <p class="text-muted">Danh sách các courses mà bạn phụ trách.</p>
        </div>
        <button class="btn lms-btn-primary"><i class="bi bi-plus-lg me-1"></i> Tạo khóa học</button>
    </div>
</div>

@if (!Session.IsLoggedIn)
{
    <div class="alert alert-warning">Vui lòng đăng nhập để xem danh sách.</div>
}
else if (Session.CurrentRole?.Name != "SME" && Session.CurrentRole?.Name != "Admin")
{
    <div class="alert alert-danger">Màn hình này dành riêng cho chuyên gia nội dung (SME). Tài khoản của bạn là @Session.CurrentRole?.Name.</div>
}
else if (courses == null)
{
    <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
}
else
{
    <div class="row g-4">
        @if (!courses.Any())
        {
            <div class="col-12">
                <div class="lms-card p-5 text-center text-muted">
                    <i class="bi bi-folder2-open display-4 mb-3"></i>
                    <h5>Chưa có khóa học nào</h5>
                    <p>Bạn chưa được phân công làm Owner cho bất kỳ khóa học nào.</p>
                </div>
            </div>
        }
        else
        {
            @foreach (var c in courses)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="lms-card h-100 d-flex flex-column">
                        <div class="lms-section-header pb-0 border-0 pt-3 px-3 d-flex justify-content-between align-items-center">
                            <span class="badge @(c.Status == "Published" ? "bg-success" : "bg-warning text-dark")">@c.Status</span>
                            <span class="text-muted small">v@(c.Version)</span>
                        </div>
                        <div class="p-4 flex-grow-1">
                            <h5 class="fw-bold mb-2">@c.Title</h5>
                            <p class="text-muted small mb-0" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                @c.Description
                            </p>
                        </div>
                        <div class="p-3 border-top" style="background: var(--lms-surface);">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted small"><i class="bi bi-calendar3"></i> @c.CreatedAt.ToString("dd/MM/yyyy")</span>
                                <a href="/course-structure?id=@c.Id" class="btn lms-btn-secondary btn-sm">Xem cấu trúc</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
}

@code {
    private List<Course>? courses;

    protected override async Task OnInitializedAsync()
    {
        Session.OnChange += StateHasChanged;
        if (Session.IsLoggedIn) await LoadData();
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Session.IsLoggedIn)
        {
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        if (Session.CurrentUser == null) return;
        
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            
            if (Session.CurrentRole?.Name == "Admin")
            {
                courses = await db.Courses.OrderByDescending(c => c.CreatedAt).ToListAsync();
            }
            else 
            {
                courses = await db.Courses.Where(c => c.OwnerSmeId == Session.CurrentUser.Id)
                                          .OrderByDescending(c => c.CreatedAt).ToListAsync();
                
                if(!courses.Any())
                {
                    courses = await db.Courses.ToListAsync();
                }
            }
        }
        catch
        {
            courses = new();
        }
    }

    public void Dispose()
    {
        Session.OnChange -= StateHasChanged;
    }
}
