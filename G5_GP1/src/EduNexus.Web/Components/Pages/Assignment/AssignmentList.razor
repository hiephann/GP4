@page "/assignments"
@inject IDbContextFactory<EduNexusDbContext> DbFactory

<PageTitle>Quản Lý Bài Tập — EduNexus</PageTitle>

<!-- Page Header -->
<div class="page-header d-flex justify-content-between align-items-end">
    <div>
        <h2>Quản Lý Bài Tập <span class="screen-tag">Assignment · FT-05</span></h2>
        <p class="text-muted mb-0">Tạo bài tập tự luận, cấu hình rubric đánh giá và theo dõi bài nộp.</p>
    </div>
</div>

<!-- Step Flow Navigator -->
<div class="lms-step-flow">
    <a class="step active" href="assignments"><i class="bi bi-list-task"></i> 1. Tạo bài tập</a>
    <div class="step-divider"></div>
    <a class="step" href="assignment-detail"><i class="bi bi-file-earmark-text"></i> 2. Cấu hình Rubric</a>
    <div class="step-divider"></div>
    <a class="step" href="assignment-result"><i class="bi bi-clipboard-check"></i> 3. Chấm &amp; kết quả</a>
</div>
<div class="lms-step-flow d-none">
    <a class="step active" href="assignments">
        <i class="bi bi-list-task"></i> 1. Tạo Bài Tập
    </a>
    <div class="step-divider"></div>
    <a class="step" href="assignment-detail">
        <i class="bi bi-file-earmark-text"></i> 2. Cấu Hình Rubric
    </a>
    <div class="step-divider"></div>
    <a class="step" href="assignment-submit">
        <i class="bi bi-upload"></i> 3. Nộp Bài
    </a>
    <div class="step-divider"></div>
    <a class="step" href="assignment-result">
        <i class="bi bi-clipboard-check"></i> 4. Kết Quả
    </a>
</div>

<!-- Stats Summary -->
@if (items is not null)
{
    <div class="row g-3 mb-4 fade-in">
        <div class="col-md-3">
            <div class="lms-stat-card">
                <div class="stat-icon" style="background: var(--lms-primary-light); color: var(--lms-primary);">
                    <i class="bi bi-file-earmark-text"></i>
                </div>
                <div>
                    <div class="stat-value">@items.Count</div>
                    <div class="stat-label">Tổng bài tập</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="lms-stat-card">
                <div class="stat-icon" style="background: var(--lms-success-light); color: var(--lms-success);">
                    <i class="bi bi-check-circle"></i>
                </div>
                <div>
                    <div class="stat-value">@items.Count(a => a.Status == "Published")</div>
                    <div class="stat-label">Đã xuất bản</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="lms-stat-card">
                <div class="stat-icon" style="background: var(--lms-warning-light); color: var(--lms-warning);">
                    <i class="bi bi-pencil-square"></i>
                </div>
                <div>
                    <div class="stat-value">@items.Count(a => a.Status == "Draft")</div>
                    <div class="stat-label">Bản nháp</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="lms-stat-card">
                <div class="stat-icon" style="background: var(--lms-info-light); color: var(--lms-info);">
                    <i class="bi bi-calendar-event"></i>
                </div>
                <div>
                    <div class="stat-value">@items.Count(a => a.DueDate.HasValue && a.DueDate.Value > DateTime.UtcNow)</div>
                    <div class="stat-label">Còn hạn nộp</div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Create New Assignment Form -->
<div class="lms-card p-4 mb-4 fade-in">
    <div class="lms-section-header">
        <i class="bi bi-plus-circle"></i>
        <div>
            <h5>Tạo Bài Tập Mới</h5>
            <div class="section-subtitle">Chọn module và đặt tiêu đề cho bài tập tự luận.</div>
        </div>
    </div>
    <div class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="lms-label"><i class="bi bi-collection"></i> Module</label>
            <select class="form-select lms-input" @bind="newModuleId" id="select-module">
                <option value="">— Chọn module —</option>
                @if (modules is not null)
                {
                    @foreach (var m in modules) { <option value="@m.Id">@m.Title</option> }
                }
            </select>
        </div>
        <div class="col-md-5">
            <label class="lms-label"><i class="bi bi-type"></i> Tiêu đề bài tập</label>
            <input class="form-control lms-input" placeholder="VD: Phân tích nghiệp vụ hệ thống bán hàng..." 
                   @bind="newTitle" @bind:event="oninput" id="input-title" />
        </div>
        <div class="col-md-3">
            <button class="btn lms-btn-primary w-100" @onclick="Add" 
                    disabled="@(string.IsNullOrWhiteSpace(newTitle) || string.IsNullOrWhiteSpace(newModuleId))"
                    id="btn-create">
                <i class="bi bi-plus-circle me-1"></i> Tạo Bài Tập
            </button>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(createMessage))
    {
        <div class="mt-3">
            <span class="lms-toast lms-toast-success">
                <i class="bi bi-check-circle-fill"></i> @createMessage
            </span>
        </div>
    }
</div>

<!-- Assignment List Table -->
@if (items is null)
{
    <div class="lms-card p-4">
        <div class="skeleton mb-3" style="height: 20px; width: 40%;"></div>
        <div class="skeleton mb-2" style="height: 48px; width: 100%;"></div>
        <div class="skeleton mb-2" style="height: 48px; width: 100%;"></div>
        <div class="skeleton" style="height: 48px; width: 100%;"></div>
    </div>
}
else if (items.Count == 0)
{
    <div class="lms-card">
        <div class="lms-empty-state">
            <div class="empty-icon"><i class="bi bi-journal-text"></i></div>
            <h4>Chưa có bài tập nào</h4>
            <p>Hãy tạo bài tập đầu tiên để bắt đầu quy trình đánh giá tự luận.</p>
        </div>
    </div>
}
else
{
    <div class="lms-card overflow-hidden slide-up">
        <div class="table-responsive">
            <table class="table lms-table mb-0">
                <thead>
                    <tr>
                        <th class="ps-4" style="width: 5%;">#</th>
                        <th style="width: 35%;">Tiêu Đề Bài Tập</th>
                        <th style="width: 15%;">Module</th>
                        <th style="width: 15%;">Hạn Nộp</th>
                        <th style="width: 12%;">Trạng Thái</th>
                        <th class="text-end pe-4" style="width: 18%;">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int rowIndex = 0; }
                    @foreach (var a in items)
                    {
                        rowIndex++;
                        <tr>
                            <td class="ps-4 text-muted fw-bold">@rowIndex</td>
                            <td>
                                <div class="fw-bold">@a.Title</div>
                                <div class="small text-muted mt-1">
                                    <i class="bi bi-clock me-1"></i>@a.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </div>
                            </td>
                            <td>
                                @{ var mod = modules?.FirstOrDefault(m => m.Id == a.ModuleId); }
                                @if (mod != null)
                                {
                                    <span class="small fw-bold text-muted">@mod.Title</span>
                                }
                                else
                                {
                                    <span class="small fst-italic text-muted">—</span>
                                }
                            </td>
                            <td>
                                @if (a.DueDate.HasValue)
                                {
                                    var isOverdue = a.DueDate.Value < DateTime.UtcNow;
                                    <span class="@(isOverdue ? "text-danger" : "text-muted") small">
                                        <i class="bi bi-calendar-event me-1"></i>@a.DueDate.Value.ToString("dd/MM/yyyy")
                                        @if (isOverdue)
                                        {
                                            <span class="d-block small fw-bold">Đã hết hạn</span>
                                        }
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic small">Chưa đặt hạn</span>
                                }
                            </td>
                            <td>
                                @if (a.Status == "Published")
                                {
                                    <span class="lms-badge lms-badge-published">
                                        <i class="bi bi-check-circle-fill"></i> Published
                                    </span>
                                }
                                else
                                {
                                    <span class="lms-badge lms-badge-draft">
                                        <i class="bi bi-pencil"></i> Draft
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a class="btn btn-sm lms-btn-secondary" href="@($"assignment-detail?id={a.Id}")"
                                       title="Cấu hình Rubric">
                                        <i class="bi bi-gear me-1"></i> Rubric
                                    </a>
                                    <button class="btn btn-sm lms-btn-danger" @onclick="() => Delete(a.Id)"
                                            title="Xóa bài tập">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<AssignmentItem>? items;
    private List<Module>? modules;
    private string newTitle = "";
    private string? newModuleId;
    private string? createMessage;

    protected override async Task OnInitializedAsync()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        modules = await db.Modules.OrderBy(m => m.Title).ToListAsync();
        await Load();
    }

    private async Task Load()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        items = await db.Assignments.OrderByDescending(a => a.CreatedAt).ToListAsync();
    }

    private async Task Add()
    {
        if (string.IsNullOrWhiteSpace(newTitle) || !Guid.TryParse(newModuleId, out var mid)) return;
        using var db = await DbFactory.CreateDbContextAsync();
        db.Assignments.Add(new AssignmentItem
        {
            Id = Guid.NewGuid(),
            ModuleId = mid,
            Title = newTitle.Trim(),
            Status = "Draft",
            CreatedAt = DateTime.UtcNow
        });
        await db.SaveChangesAsync();

        createMessage = $"Đã tạo bài tập \"{newTitle.Trim()}\" thành công!";
        newTitle = "";
        newModuleId = null;
        await Load();

        // Auto-clear message
        StateHasChanged();
        await Task.Delay(3000);
        createMessage = null;
        StateHasChanged();
    }

    private async Task Delete(Guid id)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var item = await db.Assignments.FindAsync(id);
        if (item is not null)
        {
            db.Assignments.Remove(item);
            await db.SaveChangesAsync();
            await Load();
        }
    }
}
