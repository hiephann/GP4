@page "/reset-password"
@layout EduNexus.Web.Components.Layout.EmptyLayout
@using EduNexus.Api.Common.Entities
@inject IDbContextFactory<EduNexusDbContext> DbFactory
@inject NavigationManager NavManager

<PageTitle>Đặt lại mật khẩu — EduNexus G5</PageTitle>

<div class="row g-0" style="min-height: 100vh;">
    <div class="col-md-12 d-flex justify-content-center align-items-center bg-light">
        <div class="lms-card p-5" style="max-width: 450px; width: 100%;">
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center bg-success bg-opacity-10 rounded-circle mb-3" 
                     style="width: 70px; height: 70px; color: var(--bs-success); font-size: 2rem;">
                    <i class="bi bi-shield-lock-fill"></i>
                </div>
                <h3 class="fw-bold">Tạo mật khẩu mới</h3>
                <p class="text-muted small">Mật khẩu mới của bạn phải khác với các mật khẩu đã sử dụng trước đây.</p>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger py-2 small">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @errorMessage
                </div>
            }

            @if (isSuccess)
            {
                <div class="alert alert-success py-3 text-center">
                    <i class="bi bi-check-circle-fill d-block fs-1 mb-2 text-success"></i>
                    <strong>Thành công!</strong> Mật khẩu của bạn đã được cập nhật.<br/>
                    <a href="/login" class="btn btn-success mt-3 px-4 rounded-pill">Về trang đăng nhập</a>
                </div>
            }
            else
            {
                <form @onsubmit="HandleReset">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-dark">Mật khẩu mới</label>
                        <input type="password" class="form-control lms-input" @bind="newPassword" required placeholder="Tối thiểu 8 ký tự">
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label fw-bold small text-dark">Nhập lại mật khẩu mới</label>
                        <input type="password" class="form-control lms-input" @bind="confirmPassword" required placeholder="Tối thiểu 8 ký tự">
                    </div>

                    <button type="submit" class="btn btn-success w-100 py-2 fw-bold mb-3" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Xác nhận đặt lại
                    </button>
                </form>
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    private string newPassword = "";
    private string confirmPassword = "";
    private string errorMessage = "";
    private bool isSuccess;
    private bool isLoading;

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(Token))
        {
            errorMessage = "Liên kết không hợp lệ hoặc không có mã Token.";
        }
    }

    private async Task HandleReset()
    {
        if (string.IsNullOrEmpty(Token)) return;
        if (newPassword != confirmPassword)
        {
            errorMessage = "Mật khẩu xác nhận không khớp.";
            return;
        }

        isLoading = true;
        errorMessage = "";

        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var resetRecord = await db.PasswordResetTokens
                .FirstOrDefaultAsync(t => t.TokenHash == Token && t.UsedAt == null && t.ExpiresAt > DateTime.UtcNow);

            if (resetRecord == null)
            {
                errorMessage = "Liên kết đã hết hạn hoặc không tồn tại.";
                isLoading = false;
                return;
            }

            var user = await db.Users.FindAsync(resetRecord.UserId);
            if (user != null)
            {
                // In a real app, hash the new password. Here we mock the hash format
                user.PasswordHash = "$2a$12$newMockHash_ForDemo";
                
                resetRecord.UsedAt = DateTime.UtcNow;
                await db.SaveChangesAsync();
                isSuccess = true;
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Lỗi hệ thống: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}
