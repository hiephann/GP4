@page "/dashboard"
@using EduNexus.Api.Common.Entities
@using EduNexus.Web.Services
@inject UserSession Session
@inject IDbContextFactory<EduNexusDbContext> DbFactory
@implements IDisposable

<PageTitle>Bảng điều khiển — EduNexus</PageTitle>

<div class="page-header mb-4">
    <h2>Bảng điều khiển @(Session.CurrentRole?.Name == "Admin" ? "(Quản trị viên)" : "Học viên") <span class="screen-tag">Common</span></h2>
    <p class="text-muted">Danh sách các courses, classes, và các packages.</p>
</div>

@if (!Session.IsLoggedIn)
{
    <div class="alert alert-warning">Vui lòng đăng nhập để xem thông tin học tập của bạn.</div>
}
else if (!string.IsNullOrEmpty(loadError))
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-2"></i>@loadError
        <button class="btn btn-sm btn-outline-danger ms-3" @onclick="RetryLoad">Thử lại</button>
    </div>
}
else if (courses == null)
{
    <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
}
else
{
    <div class="row g-4">
        <div class="col-md-12">
            <h5 class="fw-bold mb-3"><i class="bi bi-collection-play text-primary me-2"></i> Khóa học</h5>
            @if (!courses.Any())
            {
                <div class="lms-card p-4 text-center text-muted">Chưa có khóa học nào.</div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var c in courses)
                    {
                        <div class="col-md-4">
                            <div class="lms-card h-100 p-3">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="fw-bold mb-0">@c.Title</h6>
                                    <span class="badge bg-success">@c.Status</span>
                                </div>
                                <p class="text-muted small mb-3">@c.Description</p>
                                <a href="/progress" class="btn lms-btn-primary btn-sm w-100">Tiếp tục học</a>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
        
        <div class="col-md-6">
            <h5 class="fw-bold mb-3"><i class="bi bi-people-fill text-info me-2"></i> Lớp học (Classes)</h5>
            <div class="lms-card p-0 overflow-hidden">
                @if (classes == null || !classes.Any())
                {
                    <div class="p-4 text-center text-muted">Chưa tham gia lớp học nào.</div>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var cl in classes)
                        {
                            <li class="list-group-item p-3">
                                <div class="fw-bold">@cl.Name</div>
                                <div class="small text-muted mt-1">
                                    <i class="bi bi-calendar3"></i> 
                                    @(cl.StartDate?.ToString("dd/MM/yyyy") ?? "N/A") - @(cl.EndDate?.ToString("dd/MM/yyyy") ?? "N/A")
                                    <span class="badge bg-info ms-2">@cl.Status</span>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>

        <div class="col-md-6">
            <h5 class="fw-bold mb-3"><i class="bi bi-box2-heart text-warning me-2"></i> Gói thành viên (Packages)</h5>
            <div class="lms-card p-0 overflow-hidden">
                @if (packages == null || !packages.Any())
                {
                    <div class="p-4 text-center text-muted">Chưa đăng ký gói nào.</div>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var p in packages)
                        {
                            <li class="list-group-item p-3">
                                <div class="fw-bold">Gói thành viên</div>
                                <div class="small text-muted mt-1">
                                    Hết hạn: @p.ExpiresAt.ToString("dd/MM/yyyy HH:mm")
                                    <span class="badge @(p.Status == "Active" ? "bg-success" : "bg-danger") ms-2">@p.Status</span>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
}

@code {
    private List<Course>? courses;
    private List<EduNexus.Api.Common.Entities.Class>? classes;
    private List<PackageSubscription>? packages;
    private string? loadError;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Session.IsLoggedIn)
        {
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task RetryLoad()
    {
        loadError = null;
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            if (Session.CurrentUser == null) return;
            var sid = Session.CurrentUser.Id;

            using var db = await DbFactory.CreateDbContextAsync();
            
            if (Session.CurrentRole?.Name == "Admin")
            {
                courses = await db.Courses.ToListAsync();
                classes = await db.Classes.ToListAsync();
                packages = await db.PackageSubscriptions.ToListAsync();
            }
            else
            {
                // Khóa học thông qua AccessGrants
                var courseIds = await db.AccessGrants
                    .Where(a => a.StudentId == sid && !a.IsRevoked && a.CourseId != null)
                    .Select(a => a.CourseId).ToListAsync();
                
                if (courseIds.Count == 0)
                {
                    courses = await db.Courses.Take(3).ToListAsync(); // Demo fallback
                }
                else
                {
                    courses = await db.Courses.Where(c => courseIds.Contains(c.Id)).ToListAsync();
                }

                var classIds = await db.ClassStudents.Where(cs => cs.StudentId == sid).Select(cs => cs.ClassId).ToListAsync();
                classes = await db.Classes.Where(c => classIds.Contains(c.Id)).ToListAsync();
                packages = await db.PackageSubscriptions.Where(ps => ps.StudentId == sid).ToListAsync();
            }
        }
        catch (Exception ex)
        {
            loadError = "Không thể tải dữ liệu: " + (ex.InnerException?.Message ?? ex.Message);
            courses = new();
            classes = new();
            packages = new();
        }
    }

    public void Dispose()
    {
        Session.OnChange -= StateHasChanged;
    }
}
