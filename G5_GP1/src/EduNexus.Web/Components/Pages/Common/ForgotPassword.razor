@page "/forgot-password"
@layout EduNexus.Web.Components.Layout.EmptyLayout
@using EduNexus.Api.Common.Entities
@inject IDbContextFactory<EduNexusDbContext> DbFactory

<PageTitle>Quên mật khẩu — EduNexus G5</PageTitle>

<div class="row g-0" style="min-height: 100vh;">
    <div class="col-md-12 d-flex justify-content-center align-items-center bg-light">
        <div class="lms-card p-5" style="max-width: 450px; width: 100%;">
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 rounded-circle mb-3" 
                     style="width: 70px; height: 70px; color: var(--lms-primary); font-size: 2rem;">
                    <i class="bi bi-key-fill"></i>
                </div>
                <h3 class="fw-bold">Quên mật khẩu?</h3>
                <p class="text-muted small">Nhập email của bạn để nhận liên kết đặt lại mật khẩu.</p>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger py-2 small">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @errorMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(successToken))
            {
                <div class="alert alert-success py-3 small">
                    <i class="bi bi-check-circle-fill me-2"></i> Email hướng dẫn đã được gửi!
                    <hr/>
                    <strong>Chế độ Demo:</strong> Click vào link bên dưới để đi tới trang đặt lại mật khẩu:
                    <br/>
                    <a href="/reset-password?token=@successToken" class="fw-bold" style="word-break: break-all;">
                        /reset-password?token=@successToken
                    </a>
                </div>
            }
            else
            {
                <form @onsubmit="HandleSubmit">
                    <div class="mb-4">
                        <label class="form-label fw-bold small text-dark">Email đã đăng ký</label>
                        <input type="email" class="form-control lms-input" @bind="email" required placeholder="name@domain.com">
                    </div>

                    <button type="submit" class="btn lms-btn-primary w-100 py-2 fw-bold mb-3" disabled="@isLoading">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Gửi liên kết khôi phục
                    </button>
                    
                    <div class="text-center">
                        <a href="/login" class="text-decoration-none small text-muted fw-bold">
                            <i class="bi bi-arrow-left me-1"></i> Quay lại đăng nhập
                        </a>
                    </div>
                </form>
            }
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string errorMessage = "";
    private string successToken = "";
    private bool isLoading;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(email)) return;
        
        isLoading = true;
        errorMessage = "";
        
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var user = await db.Users.FirstOrDefaultAsync(u => u.Email == email);
            
            if (user == null)
            {
                // To prevent email enumeration, pretend it succeeded
                await Task.Delay(1000);
                errorMessage = "Nếu email hợp lệ, bạn sẽ nhận được hướng dẫn.";
            }
            else
            {
                // Generate demo token
                var token = Guid.NewGuid();
                var resetToken = new PasswordResetToken
                {
                    Id = token,
                    UserId = user.Id,
                    TokenHash = token.ToString(), // Simple demo
                    ExpiresAt = DateTime.UtcNow.AddHours(1),
                    CreatedAt = DateTime.UtcNow
                };
                
                db.PasswordResetTokens.Add(resetToken);
                await db.SaveChangesAsync();
                
                successToken = token.ToString();
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Đã xảy ra lỗi hệ thống: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}
