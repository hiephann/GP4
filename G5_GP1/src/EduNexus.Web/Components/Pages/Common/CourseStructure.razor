@page "/course-structure"
@inject IDbContextFactory<EduNexusDbContext> DbFactory

<PageTitle>Course Structure</PageTitle>

<div class="page-header">
    <h2>Course Structure <span class="screen-tag">Common · FT-01</span></h2>
    <p class="text-muted">Module list & contents (lessons, flashcards, assignments, question bank, quizzes).</p>
</div>

<div class="mb-3" style="max-width:480px">
    <label class="form-label">Chọn khóa học</label>
    <select class="form-select lms-input" value="@selectedId" @onchange="OnCourseChanged">
        <option value="">-- chọn --</option>
        @if (courses is not null)
        {
            @foreach (var c in courses) { <option value="@c.Id">@c.Title</option> }
        }
    </select>
</div>

@if (selectedId is not null)
{
    <div class="d-flex gap-2 mb-3">
        <input class="form-control lms-input" style="max-width:320px" @bind="newModuleTitle" placeholder="Tên module mới" />
        <button class="btn lms-btn-primary" @onclick="AddModule">+ Thêm module</button>
    </div>

    @if (modules!.Count == 0)
    {
        <p class="text-muted">Khóa học chưa có module.</p>
    }
    else
    {
        <table class="table lms-table">
            <thead><tr><th>#</th><th>Module</th><th>Lessons</th><th>Questions</th><th>Flashcards</th><th>Assignments</th></tr></thead>
            <tbody>
                @foreach (var m in modules)
                {
                    <tr>
                        <td>@m.OrderIndex</td>
                        <td>@m.Title</td>
                        <td>@counts[m.Id].l</td>
                        <td>@counts[m.Id].q</td>
                        <td>@counts[m.Id].f</td>
                        <td>@counts[m.Id].a</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private List<Course>? courses;
    private Guid? selectedId;
    private List<Module>? modules;
    private Dictionary<Guid, (int l, int q, int f, int a)> counts = new();
    private string newModuleTitle = "";

    [Microsoft.AspNetCore.Components.SupplyParameterFromQuery]
    [Microsoft.AspNetCore.Components.Parameter] public Guid? Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        courses = await db.Courses.OrderBy(c => c.Title).ToListAsync();
        if (Id is not null) { selectedId = Id; await LoadModules(); }
    }

    private async Task OnCourseChanged(ChangeEventArgs e)
    {
        selectedId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null;
        await LoadModules();
    }

    private async Task LoadModules()
    {
        if (selectedId is null) { modules = null; return; }
        using var db = await DbFactory.CreateDbContextAsync();
        modules = await db.Modules.Where(m => m.CourseId == selectedId).OrderBy(m => m.OrderIndex).ToListAsync();
        counts.Clear();
        foreach (var m in modules)
        {
            counts[m.Id] = (
                await db.Lessons.CountAsync(x => x.ModuleId == m.Id),
                await db.Questions.CountAsync(x => x.ModuleId == m.Id),
                await db.Flashcards.CountAsync(x => x.ModuleId == m.Id),
                await db.Assignments.CountAsync(x => x.ModuleId == m.Id)
            );
        }
    }

    private async Task AddModule()
    {
        if (selectedId is null || string.IsNullOrWhiteSpace(newModuleTitle)) return;
        using var db = await DbFactory.CreateDbContextAsync();
        var order = await db.Modules.CountAsync(m => m.CourseId == selectedId) + 1;
        db.Modules.Add(new Module { Id = Guid.NewGuid(), CourseId = selectedId.Value, Title = newModuleTitle.Trim(), OrderIndex = order, CreatedAt = DateTime.UtcNow });
        await db.SaveChangesAsync();
        newModuleTitle = "";
        await LoadModules();
    }
}
