@inherits LayoutComponentBase
@implements IDisposable

<div class="lms-layout">
    <div class="lms-sidebar">
        <NavMenu />
    </div>

    <div class="lms-main">
        <header class="lms-header justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-list fs-4 text-muted d-md-none" style="cursor: pointer;"></i>
                <h5 class="mb-0 fw-bold" style="color: var(--lms-text-main);">Hệ thống Học tập &amp; Đào tạo EduNexus</h5>
            </div>
            
            <div class="d-flex align-items-center gap-4">
                <div class="position-relative" style="cursor: pointer;">
                    <i class="bi bi-bell fs-5 text-muted"></i>
                    <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle">
                        <span class="visually-hidden">New alerts</span>
                    </span>
                </div>
                
                <div class="d-flex align-items-center gap-2" style="cursor: pointer;" @onclick="Logout">
                    @if (Session.IsLoggedIn)
                    {
                        var u = Session.CurrentUser!;
                        var initials = string.IsNullOrWhiteSpace(u.DisplayName) ? "U" : u.DisplayName.Substring(0, 1).ToUpper();
                        <div class="d-flex align-items-center justify-content-center fw-bold rounded-circle" 
                             style="width: 36px; height: 36px; background: var(--lms-primary-gradient); color: white; font-size: 0.9rem;">
                            @initials
                        </div>
                        <div class="d-none d-md-block text-start">
                            <div class="fw-bold text-dark" style="font-size: 0.85rem; line-height: 1.2;">@u.DisplayName</div>
                            <div class="text-muted" style="font-size: 0.75rem;">@(Session.CurrentRole?.Name ?? "User")</div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center fw-bold rounded-circle" 
                             style="width: 36px; height: 36px; background: #e0e0e0; color: #777; font-size: 0.9rem;">
                            ?
                        </div>
                        <div class="d-none d-md-block text-start">
                            <div class="fw-bold text-dark" style="font-size: 0.85rem; line-height: 1.2;">Chưa đăng nhập</div>
                            <div class="text-muted" style="font-size: 0.75rem;">Khách</div>
                        </div>
                    }
                    <i class="bi bi-box-arrow-right text-muted small ms-2" title="Đăng xuất"></i>
                </div>
            </div>
        </header>

        <main class="lms-content">
            <ErrorBoundary @ref="errorBoundary">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="ex">
                    <div class="alert alert-danger m-4" role="alert">
                        <h5 class="alert-heading"><i class="bi bi-exclamation-triangle-fill me-2"></i>Đã xảy ra lỗi</h5>
                        <p>Trang này gặp sự cố khi tải dữ liệu. Vui lòng thử lại.</p>
                        <hr>
                        <button class="btn btn-outline-danger btn-sm" @onclick="RecoverFromError">
                            <i class="bi bi-arrow-clockwise me-1"></i> Thử lại
                        </button>
                    </div>
                </ErrorContent>
            </ErrorBoundary>
        </main>
    </div>
</div>

<div id="blazor-error-ui" style="display: none;">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    [Inject] EduNexus.Web.Services.UserSession Session { get; set; } = default!;
    [Inject] NavigationManager Nav { get; set; } = default!;
    
    private ErrorBoundary? errorBoundary;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await Session.InitializeAsync();
                Session.OnChange += StateHasChanged;
                StateHasChanged();
            }
            catch
            {
                // Prevent circuit crash on init
            }
        }
    }

    private void RecoverFromError()
    {
        errorBoundary?.Recover();
    }

    public void Dispose()
    {
        Session.OnChange -= StateHasChanged;
    }

    private async Task Logout()
    {
        try
        {
            await Session.LogoutAsync();
            Nav.NavigateTo("/login", forceLoad: true);
        }
        catch
        {
            Nav.NavigateTo("/login", forceLoad: true);
        }
    }
}
