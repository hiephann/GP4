<div class="nav-item px-3">
    <NavLink class="nav-link" href="@Href">
        <span class="bi @Icon" aria-hidden="true"></span> @Text
    </NavLink>
</div>

@code {
    [Parameter, EditorRequired] public string Href { get; set; } = "";
    [Parameter, EditorRequired] public string Text { get; set; } = "";
    [Parameter] public string Icon { get; set; } = "bi-dot";
}
