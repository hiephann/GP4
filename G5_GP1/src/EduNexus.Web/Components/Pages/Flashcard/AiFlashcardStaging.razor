@page "/ai-flashcard-staging"
@inject IDbContextFactory<EduNexusDbContext> DbFactory
@inject EduNexus.Api.Flashcard.Services.IFlashcardService FlashcardService

<PageTitle>AI Flashcard Staging</PageTitle>

<div class="page-header">
    <h2>AI Flashcard Staging <span class="screen-tag">Flashcard · BR-07</span></h2>
    <p class="text-muted">AI tạo cặp thuật ngữ–định nghĩa vào khu vực chờ duyệt.</p>
</div>

<div class="card mb-3">
    <div class="card-body">
        <label class="form-label">Văn bản nguồn</label>
        <textarea class="form-control mb-2" rows="3" @bind="source" placeholder="Dán nội dung để AI tạo flashcard..."></textarea>
        <select class="form-select mb-2" @bind="moduleId">
            <option value="">-- Chọn module nhận flashcard sau khi duyệt --</option>
            @if (modules is not null)
            {
                @foreach (var module in modules)
                {
                    <option value="@module.Id">@module.Title</option>
                }
            }
        </select>
        <button class="btn lms-btn-primary" @onclick="Generate" disabled="@(string.IsNullOrWhiteSpace(source) || isGenerating)">
            @if (isGenerating)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                <span>Đang sinh thẻ...</span>
            }
            else
            {
                <span class="bi bi-robot"></span>
                <span>Sinh thẻ</span>
            }
        </button>
    </div>
</div>

<h6>Khu vực chờ duyệt</h6>
@if (drafts is null) { <p>Đang tải...</p> }
else
{
    <table class="table lms-table">
        <thead><tr><th>Nội dung sinh ra</th><th>Trạng thái</th><th></th></tr></thead>
        <tbody>
            @foreach (var d in drafts)
            {
                <tr>
                    <td style="max-width:520px">@d.GeneratedJson</td>
                    <td><span class="badge bg-@(d.Status=="Approved"?"success":"warning")">@d.Status</span></td>
                    <td>@if (d.Status == "Pending") { <button class="btn btn-sm lms-btn-success" @onclick="() => Approve(d.Id)">Phê duyệt</button> }</td>
                </tr>
            }
            @if (drafts.Count == 0) { <tr><td colspan="3" class="text-muted">Chưa có bản nháp.</td></tr> }
        </tbody>
    </table>
}

@code {
    private string source = "";
    private string? moduleId;
    private List<Module>? modules;
    private List<AiFlashcardDraft>? drafts;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        drafts = await db.AiFlashcardDrafts.OrderByDescending(d => d.CreatedAt).ToListAsync();
        modules = await db.Modules.OrderBy(m => m.OrderIndex).ThenBy(m => m.Title).ToListAsync();
    }

    [Inject] private EduNexus.Api.Infrastructure.Ai.IAiContentService AiService { get; set; } = default!;
    private bool isGenerating = false;

    private async Task Generate()
    {
        if (string.IsNullOrWhiteSpace(source) || !Guid.TryParse(moduleId, out var targetModuleId)) return;
        isGenerating = true;
        StateHasChanged();

        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var anyUser = await db.Users.Select(u => (Guid?)u.Id).FirstOrDefaultAsync();
            await FlashcardService.GenerateDraftAsync(
                new EduNexus.Api.Flashcard.DTOs.GenerateFlashcardRequest(targetModuleId, source), anyUser ?? Guid.Empty);
            source = "";
        }
        finally
        {
            isGenerating = false;
            await Load();
        }
    }

    private async Task Approve(Guid id)
    {
        await FlashcardService.ApproveDraftAsync(id);
        await Load();
    }
}
